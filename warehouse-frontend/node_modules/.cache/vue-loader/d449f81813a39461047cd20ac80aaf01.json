n          </template>\n          <el-menu-item index=\"/category\">分类管理</el-menu-item>\n          <el-menu-item index=\"/product\">商品信息</el-menu-item>\n        </el-submenu>\n        <el-submenu index=\"4\">\n          <template slot=\"title\">\n            <i class=\"el-icon-box\"></i>\n            <span>库存管理</span>\n          </template>\n          <el-menu-item index=\"/stock\">库存查询</el-menu-item>\n        </el-submenu>\n        <el-submenu index=\"5\">\n          <template slot=\"title\">\n            <i class=\"el-icon-document\"></i>\n            <span>订单管理</span>\n          </template>\n          <el-menu-item index=\"/inbound\">入库管理</el-menu-item>\n          <el-menu-item index=\"/outbound\">出库管理</el-menu-item>\n        </el-submenu>\n        <el-submenu index=\"6\">\n          <template slot=\"title\">\n            <i class=\"el-icon-s-custom\"></i>\n            <span>合作伙伴</span>\n          </template>\n          <el-menu-item index=\"/supplier\">供应商管理</el-menu-item>\n          <el-menu-item index=\"/customer\">客户管理</el-menu-item>\n        </el-submenu>\n      </el-menu>\n    </el-aside>\n    <el-container>\n      <el-header>\n        <div class=\"header-title\">{{ $route.meta.title }}</div>\n        <div class=\"header-right\">\n          <span>欢迎，{{ user ? user.realName : '用户' }}</span>\n          <el-button type=\"text\" @click=\"handleLogout\">退出</el-button>\n        </div>\n      </el-header>\n      <el-main>\n        <router-view />\n      </el-main>\n    </el-container>\n  </el-container>\n</template>\n\n<script>\nimport { mapState } from 'vuex'\n\nexport default {\n  name: 'Layout',\n  computed: {\n    ...mapState(['user'])\n  },\n  methods: {\n    handleLogout() {\n      this.$confirm('确定要退出登录吗?', '提示', {\n        type: 'warning'\n      }).then(() => {\n        this.$store.dispatch('logout')\n        this.$router.push('/login')\n        this.$message.success('退出成功')\n      }).catch(() => {})\n    }\n  }\n}\n</script>\n\n<style scoped>\n.layout-container {\n  height: 100%;\n}\n\n.el-aside {\n  background-color: #304156;\n}\n\n.logo {\n  height: 60px;\n  line-height: 60px;\n  text-align: center;\n  color: #fff;\n  font-size: 18px;\n  font-weight: bold;\n  background-color: #263445;\n}\n\n.el-header {\n  background-color: #fff;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  box-shadow: 0 1px 4px rgba(0, 21, 41, 0.08);\n}\n\n.header-title {\n  font-size: 18px;\n  font-weight: bold;\n}\n\n.header-right {\n  display: flex;\n  align-items: center;\n  gap: 15px;\n}\n\n.el-menu {\n  border-right: none;\n}\n</style>\n"]}]}