{"remainingRequest":"D:\\Java_code\\trae_cangku\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\Java_code\\trae_cangku\\warehouse-frontend\\src\\views\\system\\User.vue?vue&type=style&index=0&id=0e2c73be&scoped=true&lang=css","dependencies":[{"path":"D:\\Java_code\\trae_cangku\\warehouse-frontend\\src\\views\\system\\User.vue","mtime":1773017611685},{"path":"D:\\Java_code\\trae_cangku\\warehouse-frontend\\node_modules\\css-loader\\dist\\cjs.js","mtime":1773020855185},{"path":"D:\\Java_code\\trae_cangku\\warehouse-frontend\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1773020856071},{"path":"D:\\Java_code\\trae_cangku\\warehouse-frontend\\node_modules\\postcss-loader\\src\\index.js","mtime":1773020855259},{"path":"D:\\Java_code\\trae_cangku\\warehouse-frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773020855054},{"path":"D:\\Java_code\\trae_cangku\\warehouse-frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1773020855508}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:Ci50b29sYmFyIHsKICBtYXJnaW4tYm90dG9tOiAyMHB4OwogIGRpc3BsYXk6IGZsZXg7CiAgZ2FwOiAxMHB4Owp9Cg=="},{"version":3,"sources":["User.vue"],"names":[],"mappings":";AA2KA;AACA;AACA;AACA;AACA","file":"User.vue","sourceRoot":"src/views/system","sourcesContent":["<template>\n  <div class=\"user-container\">\n    <el-card>\n      <div class=\"toolbar\">\n        <el-input v-model=\"searchName\" placeholder=\"请输入用户名\" style=\"width: 200px\" @keyup.enter.native=\"handleSearch\" clearable></el-input>\n        <el-button type=\"primary\" icon=\"el-icon-search\" @click=\"handleSearch\">搜索</el-button>\n        <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"handleAdd\">新增</el-button>\n      </div>\n      <el-table :data=\"tableData\" border stripe v-loading=\"loading\">\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\n        <el-table-column prop=\"username\" label=\"用户名\"></el-table-column>\n        <el-table-column prop=\"realName\" label=\"姓名\"></el-table-column>\n        <el-table-column prop=\"phone\" label=\"电话\"></el-table-column>\n        <el-table-column prop=\"email\" label=\"邮箱\"></el-table-column>\n        <el-table-column prop=\"status\" label=\"状态\">\n          <template slot-scope=\"scope\">\n            <el-tag :type=\"scope.row.status === 1 ? 'success' : 'danger'\">\n              {{ scope.row.status === 1 ? '启用' : '禁用' }}\n            </el-tag>\n          </template>\n        </el-table-column>\n        <el-table-column prop=\"createTime\" label=\"创建时间\" width=\"180\"></el-table-column>\n        <el-table-column label=\"操作\" width=\"180\">\n          <template slot-scope=\"scope\">\n            <el-button type=\"text\" @click=\"handleEdit(scope.row)\">编辑</el-button>\n            <el-button type=\"text\" style=\"color: #F56C6C\" @click=\"handleDelete(scope.row.id)\">删除</el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n      <el-pagination\n        @size-change=\"handleSizeChange\"\n        @current-change=\"handleCurrentChange\"\n        :current-page=\"current\"\n        :page-sizes=\"[10, 20, 50]\"\n        :page-size=\"size\"\n        layout=\"total, sizes, prev, pager, next, jumper\"\n        :total=\"total\"\n        style=\"margin-top: 20px; text-align: right\">\n      </el-pagination>\n    </el-card>\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"500px\">\n      <el-form :model=\"form\" :rules=\"rules\" ref=\"form\" label-width=\"80px\">\n        <el-form-item label=\"用户名\" prop=\"username\">\n          <el-input v-model=\"form.username\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"密码\" prop=\"password\" v-if=\"!form.id\">\n          <el-input v-model=\"form.password\" type=\"password\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"姓名\" prop=\"realName\">\n          <el-input v-model=\"form.realName\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"电话\" prop=\"phone\">\n          <el-input v-model=\"form.phone\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"邮箱\" prop=\"email\">\n          <el-input v-model=\"form.email\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"状态\" prop=\"status\">\n          <el-radio-group v-model=\"form.status\">\n            <el-radio :label=\"1\">启用</el-radio>\n            <el-radio :label=\"0\">禁用</el-radio>\n          </el-radio-group>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\">\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\n        <el-button type=\"primary\" @click=\"handleSubmit\">确定</el-button>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport request from '@/utils/request'\n\nexport default {\n  name: 'User',\n  data() {\n    return {\n      searchName: '',\n      tableData: [],\n      loading: false,\n      current: 1,\n      size: 10,\n      total: 0,\n      dialogVisible: false,\n      dialogTitle: '',\n      form: {},\n      rules: {\n        username: [{ required: true, message: '请输入用户名', trigger: 'blur' }],\n        password: [{ required: true, message: '请输入密码', trigger: 'blur' }],\n        realName: [{ required: true, message: '请输入姓名', trigger: 'blur' }]\n      }\n    }\n  },\n  created() {\n    this.loadData()\n  },\n  methods: {\n    async loadData() {\n      this.loading = true\n      try {\n        const res = await request.get('/user/page', {\n          params: {\n            current: this.current,\n            size: this.size,\n            username: this.searchName\n          }\n        })\n        this.tableData = res.data.records\n        this.total = res.data.total\n      } catch (error) {\n        console.error(error)\n      } finally {\n        this.loading = false\n      }\n    },\n    handleSearch() {\n      this.current = 1\n      this.loadData()\n    },\n    handleSizeChange(val) {\n      this.size = val\n      this.loadData()\n    },\n    handleCurrentChange(val) {\n      this.current = val\n      this.loadData()\n    },\n    handleAdd() {\n      this.dialogTitle = '新增用户'\n      this.form = { status: 1 }\n      this.dialogVisible = true\n      this.$nextTick(() => {\n        this.$refs.form && this.$refs.form.clearValidate()\n      })\n    },\n    handleEdit(row) {\n      this.dialogTitle = '编辑用户'\n      this.form = { ...row }\n      this.dialogVisible = true\n    },\n    handleDelete(id) {\n      this.$confirm('确定要删除该用户吗?', '提示', {\n        type: 'warning'\n      }).then(async () => {\n        await request.delete(`/user/${id}`)\n        this.$message.success('删除成功')\n        this.loadData()\n      }).catch(() => {})\n    },\n    handleSubmit() {\n      this.$refs.form.validate(async (valid) => {\n        if (valid) {\n          if (this.form.id) {\n            await request.put('/user', this.form)\n            this.$message.success('修改成功')\n          } else {\n            await request.post('/user', this.form)\n            this.$message.success('新增成功')\n          }\n          this.dialogVisible = false\n          this.loadData()\n        }\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.toolbar {\n  margin-bottom: 20px;\n  display: flex;\n  gap: 10px;\n}\n</style>\n"]}]}